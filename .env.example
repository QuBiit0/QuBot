# Qubot Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Core Settings
# ============================================
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars

# ============================================
# Database
# ============================================
POSTGRES_USER=qubot
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=qubot_db
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ============================================
# Redis
# ============================================
REDIS_URL=redis://redis:6379/0

# ============================================
# CORS (comma-separated)
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://app.qubot.io

# ============================================
# LLM Provider API Keys (optional)
# ============================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
GROQ_API_KEY=gsk_...
OLLAMA_HOST=http://ollama:11434

# ============================================
# Admin User (for initial setup)
# ============================================
ADMIN_EMAIL=admin@qubot.io
ADMIN_PASSWORD=admin-password-change-me

# ============================================
# Frontend URLs
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# ============================================
# Worker Configuration
# ============================================
WORKER_REPLICAS=2

# ============================================
# Monitoring (optional)
# ============================================
GRAFANA_PASSWORD=admin

# ============================================
# Email Tool (SMTP + IMAP for agent email ops)
# ============================================
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your@email.com
EMAIL_SMTP_PASSWORD=your-app-password
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993

# Legacy SMTP config (for system notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@qubot.io

# ============================================
# S3/Storage (optional, for file uploads)
# ============================================
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# ============================================
# Feature Flags
# ============================================
ENABLE_REGISTRATION=true
ENABLE_OLLAMA=true

# ============================================
# GitHub Tool (for agent GitHub operations)
# ============================================
GITHUB_TOKEN=ghp_your_personal_access_token

# ============================================
# Notification Tool Webhooks (optional)
# ============================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx

# ============================================
# Context7 (optional, for docs_search tool)
# Free tier available at context7.com
# ============================================
CONTEXT7_TOKEN=

# ============================================
# Messaging Bot Tokens (optional)
# ============================================
# Telegram Bot - Get from @BotFather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Discord Bot - Get from Discord Developer Portal
DISCORD_BOT_TOKEN=your-discord-bot-token
DISCORD_APPLICATION_ID=your-discord-app-id
DISCORD_PUBLIC_KEY=your-discord-public-key

# Slack Bot - Get from Slack API
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_APP_TOKEN=xapp-your-slack-app-token

# WhatsApp Business API
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-whatsapp-business-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-verify-token

# ============================================
# Webhook URLs (for production)
# ============================================
# Your public domain for receiving webhooks
PUBLIC_DOMAIN=https://your-domain.com
TELEGRAM_WEBHOOK_URL=${PUBLIC_DOMAIN}/api/v1/telegram/webhook
DISCORD_WEBHOOK_URL=${PUBLIC_DOMAIN}/api/v1/discord/webhook
SLACK_WEBHOOK_URL=${PUBLIC_DOMAIN}/api/v1/slack/webhook
WHATSAPP_WEBHOOK_URL=${PUBLIC_DOMAIN}/api/v1/whatsapp/webhook

# ============================================
# Additional LLM Providers (optional)
# ============================================
OPENROUTER_API_KEY=sk-or-...
DEEPSEEK_API_KEY=sk-...
KIMI_API_KEY=sk-...
MINIMAX_API_KEY=...
ZHIPU_API_KEY=...

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10

# ============================================
# Security
# ============================================
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# Task Execution
# ============================================
MAX_TASK_ITERATIONS=10
TASK_TIMEOUT_SECONDS=300
WORKER_HEARTBEAT_INTERVAL=10
WORKER_CLAIM_INTERVAL=30

# ============================================
# Default LLM Configuration
# ============================================
DEFAULT_LLM_PROVIDER=OPENAI
DEFAULT_LLM_MODEL=gpt-4o-mini
DEFAULT_LLM_TEMPERATURE=0.7
DEFAULT_LLM_MAX_TOKENS=2000
